%% hdr-extras.sty
%% Additional macros and environments for the HDR manuscript
%%
%% Usage: \usepackage{hdr-extras}  (already loaded by main.tex)

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hdr-extras}[2024/01/01 HDR extra macros]

\RequirePackage{tcolorbox}
\RequirePackage{mdframed}
\RequirePackage{pgfplots}
\RequirePackage{tikz}
\RequirePackage{siunitx}
\RequirePackage{multirow}
\RequirePackage{longtable}
\RequirePackage{algorithm}
\RequirePackage{algpseudocode}
\RequirePackage{listings}
\RequirePackage{natbib}

\pgfplotsset{compat=1.18}
\usetikzlibrary{arrows.meta, positioning, calc, shapes.geometric}

% ─────────────────────────────────────────────
%  tcolorbox styles
% ─────────────────────────────────────────────
\tcbuselibrary{skins, breakable, theorems}

% Highlighted box for key results
\tcbset{
  keyresult/.style={
    enhanced,
    colback  = usmb@blue!5,
    colframe = usmb@blue,
    fonttitle = \bfseries,
    breakable,
    left = 6pt, right = 6pt, top = 4pt, bottom = 4pt,
  },
  contribution/.style={
    enhanced,
    colback  = usmb@red!5,
    colframe = usmb@red,
    fonttitle = \bfseries,
    breakable,
    left = 6pt, right = 6pt, top = 4pt, bottom = 4pt,
  }
}

\newenvironment{keyresult}[1][Résultat clé]{%
  \begin{tcolorbox}[keyresult, title=#1]%
}{%
  \end{tcolorbox}%
}

\newenvironment{contribution}[1][Contribution]{%
  \begin{tcolorbox}[contribution, title=#1]%
}{%
  \end{tcolorbox}%
}

% ─────────────────────────────────────────────
%  Code listings style
% ─────────────────────────────────────────────
\lstset{
  basicstyle   = \ttfamily\small,
  keywordstyle = \bfseries\color{usmb@blue},
  commentstyle = \itshape\color{usmb@grey},
  stringstyle  = \color{usmb@red},
  numbers      = left,
  numberstyle  = \tiny\color{usmb@grey},
  stepnumber   = 1,
  numbersep    = 8pt,
  backgroundcolor = \color{usmb@lgrey},
  showstringspaces = false,
  breaklines   = true,
  frame        = single,
  framerule    = 0.4pt,
  rulecolor    = \color{usmb@grey},
  tabsize      = 2,
  captionpos   = b,
}

% ─────────────────────────────────────────────
%  Publications list helper
%  Usage: \begin{publist} \pubitem ... \end{publist}
% ─────────────────────────────────────────────
\newlist{publist}{enumerate}{1}
\setlist[publist]{
  label     = [\arabic*],
  leftmargin= 2.5em,
  itemsep   = 4pt,
  parsep    = 0pt
}
\newcommand{\pubitem}{\item}

% ─────────────────────────────────────────────
%  Abstract environment (bilingual)
% ─────────────────────────────────────────────
\newenvironment{hdrabstract}[1][Résumé]{%
  \begin{mdframed}[
    linecolor  = usmb@blue,
    linewidth  = 1pt,
    innerleftmargin  = 10pt,
    innerrightmargin = 10pt,
    innertopmargin   = 8pt,
    innerbottommargin= 8pt,
  ]%
  \paragraph*{\color{usmb@blue}#1}\mbox{}\\[2pt]
}{%
  \end{mdframed}%
}

% ─────────────────────────────────────────────
%  Supervisor / advisor box (for CV section)
% ─────────────────────────────────────────────
\newcommand{\studentrow}[4]{%  {Name}{Period}{Level}{Topic}
  #1 & #2 & #3 & \parbox[t]{5cm}{\raggedright #4} \\
}

\endinput
